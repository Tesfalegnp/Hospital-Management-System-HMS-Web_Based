{
  "name": "hospital-management-server",
  "version": "1.0.0",
  "description": "Enterprise Hospital Management System Backend",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "NODE_OPTIONS=\"--dns-result-order=ipv4first\" tsx watch src/server.ts",
    "build": "tsc",
    "start": "NODE_OPTIONS=\"--dns-result-order=ipv4first\" node dist/server.js",
    "seed": "NODE_OPTIONS=\"--dns-result-order=ipv4first\" tsx src/database/seed.ts",
    "check": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": [
    "hospital",
    "hms",
    "express",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.11.0",
    "multer": "^2.0.2",
    "pg": "^8.22.0",
    "prisma": "^6.19.3",
    "socket.io": "^4.8.1",
    "uuid": "^11.1.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.3.0",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.34.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
