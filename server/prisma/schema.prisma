generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ================================
// ENUMS
// ================================

enum Role {
  SUPER_ADMIN
  ADMIN
  DOCTOR
  NURSE
  RECEPTIONIST
  PHARMACIST
  LAB_TECHNICIAN
  ACCOUNTANT
  PATIENT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum BloodGroup {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
  UNKNOWN
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
  OTHER
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ================================
// HOSPITAL
// ================================

model Hospital {
  id String @id @default(cuid())

  name String

  code String @unique

  email String? @unique

  phone String?

  website String?

  address String?

  city String?

  state String?

  country String?

  isActive Boolean @default(true)

  branches Branch[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  deletedAt     DateTime?
  users         User[]
  permissions   Permission[]
  roles         RoleDefinition[]
  systemConfigs SystemConfig[]
  featureFlags  FeatureFlag[]
  apiKeys       ApiKey[]

  userRoles           UserRole[]
  permissionOverrides UserPermissionOverride[]

  @@index([name])
}

// ================================
// BRANCH
// ================================

model Branch {
  id String @id @default(cuid())

  hospitalId String

  name String

  code String

  email String?

  phone String?

  address String?

  city String?

  state String?

  country String?

  isActive Boolean @default(true)

  hospital Hospital @relation(fields: [hospitalId], references: [id], onDelete: Restrict)

  departments Department[]

  users User[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  deletedAt DateTime?

  appointments     Appointment[]
  consultations    Consultation[]
  storageLocations StorageLocation[]
  batches          MedicineBatch[]
  tariffs          Tariff[]
  invoices         Invoice[]
  wards            Ward[]
  labTestCatalogs  LabTestCatalog[]
  permissions      Permission[]
  roles            RoleDefinition[]
  systemConfigs    SystemConfig[]
  featureFlags     FeatureFlag[]
  apiKeys          ApiKey[]

  userRoles           UserRole[]
  permissionOverrides UserPermissionOverride[]

  @@unique([hospitalId, code])
  @@index([hospitalId])
}

// ================================
// DEPARTMENT
// ================================

model Department {
  id String @id @default(cuid())

  branchId String

  name String

  description String?

  isActive Boolean @default(true)

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Restrict)

  users User[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  deletedAt DateTime?

  appointments Appointment[]

  @@unique([branchId, name])
  @@index([branchId])
}

// ================================
// USER
// ================================

model User {
  id String @id @default(cuid())

  firstName String

  lastName String

  email String @unique

  phone String? @unique

  password String

  gender Gender?

  role Role

  hospitalId String?

  branchId String?

  departmentId String?

  hospital Hospital? @relation(fields: [hospitalId], references: [id], onDelete: SetNull)

  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  doctor Doctor?

  patient Patient?

  isActive Boolean @default(true)

  isEmailVerified Boolean @default(false)

  lastLogin DateTime?

  refreshToken String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  deletedAt             DateTime?
  labOrders             LabOrder[]               @relation("UserLabOrders")
  inventoryTransactions InventoryTransaction[]
  pharmacistDispenses   DispenseRecord[]         @relation("PharmacistDispenses")
  witnessDispenses      DispenseRecord[]         @relation("WitnessDispenses")
  payments              Payment[]
  recordedVitals        VitalsLog[]
  collectedSpecimens    LabOrder[]               @relation("SpecimenCollectors")
  performedLabResults   LabResult[]              @relation("PerformingTechnicians")
  approvedLabResults    LabResult[]              @relation("ApprovingPathologists")
  auditLogs             AuditLog[]
  userRoles             UserRole[]
  permissionOverrides   UserPermissionOverride[]

  @@index([email])
  @@index([role])
  @@index([branchId])
  @@index([departmentId])
}

// ================================
// DOCTOR
// ================================

model Doctor {
  id String @id @default(cuid())

  userId String @unique

  licenseNumber String @unique

  specialization String

  qualification String?

  yearsOfExperience Int?

  consultationFee Decimal?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  deletedAt DateTime?

  appointments  Appointment[]
  consultations Consultation[]
  labOrders     LabOrder[]
  prescriptions Prescription[]
  admissions    Admission[]

  @@index([specialization])
}

// ================================
// PATIENT
// ================================

model Patient {
  id String @id @default(cuid())

  userId String? @unique

  dateOfBirth DateTime?

  gender Gender?

  bloodGroup BloodGroup @default(UNKNOWN)

  maritalStatus MaritalStatus?

  occupation String?

  address String?

  emergencyContactName String?

  emergencyContactPhone String?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  deletedAt DateTime?

  appointments  Appointment[]
  consultations Consultation[]
  labOrders     LabOrder[]
  allergies     PatientAllergy[]
  prescriptions Prescription[]
  invoices      Invoice[]
  admissions    Admission[]

  @@index([bloodGroup])
}

// ================================
// APPOINTMENT
// ================================

model Appointment {
  id String @id @default(cuid())

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Restrict)

  doctorId String
  doctor   Doctor @relation(fields: [doctorId], references: [id], onDelete: Restrict)

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Restrict)

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  consultation Consultation?

  appointmentDate DateTime
  startTime       DateTime
  endTime         DateTime

  status AppointmentStatus @default(SCHEDULED)
  reason String?
  notes  String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([patientId])
  @@index([doctorId])
  @@index([branchId])
  @@index([appointmentDate])
}

// ================================
// CONSULTATION
// ================================

model Consultation {
  id String @id @default(cuid())

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Restrict)

  doctorId String
  doctor   Doctor @relation(fields: [doctorId], references: [id], onDelete: Restrict)

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Restrict)

  appointmentId String?      @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  bloodPressure   String?
  heartRate       Int?
  temperature     Decimal?
  respiratoryRate Int?
  weight          Decimal?

  chiefComplaint      String? @db.Text
  physicalExamination String? @db.Text
  diagnosis           String? @db.Text
  treatmentPlan       String? @db.Text

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  labOrders     LabOrder[]
  prescriptions Prescription[]
  invoiceItems  InvoiceItem[]

  @@index([patientId])
  @@index([doctorId])
  @@index([branchId])
}

// ================================
// LABORATORY & DIAGNOSTICS
// ================================

enum LabOrderStatus {
  PENDING
  SPECIMEN_COLLECTED
  PROCESSING
  COMPLETED
  CANCELLED
}

model LabTestCatalog {
  id             String    @id @default(cuid())
  branchId       String
  name           String
  code           String
  category       String
  price          Decimal   @db.Decimal(10, 2)
  normalRangeMin Decimal?  @db.Decimal(10, 2)
  normalRangeMax Decimal?  @db.Decimal(10, 2)
  unit           String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  branch    Branch     @relation(fields: [branchId], references: [id], onDelete: Restrict)
  labOrders LabOrder[]

  @@unique([branchId, code])
  @@index([branchId])
}

model LabOrder {
  id                    String          @id @default(uuid())
  encounterId           String
  encounter             Consultation    @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  patientId             String
  patient               Patient         @relation(fields: [patientId], references: [id], onDelete: Restrict)
  orderedById           String
  orderedBy             Doctor          @relation(fields: [orderedById], references: [id], onDelete: Restrict)
  fulfilledById         String?
  fulfilledBy           User?           @relation("UserLabOrders", fields: [fulfilledById], references: [id], onDelete: SetNull)
  labTestCatalogId      String?
  labTestCatalog        LabTestCatalog? @relation(fields: [labTestCatalogId], references: [id], onDelete: SetNull)
  testName              String
  clinicalNotes         String?         @db.Text
  status                LabOrderStatus  @default(PENDING)
  specimenCollectedAt   DateTime?
  specimenCollectedById String?
  specimenCollectedBy   User?           @relation("SpecimenCollectors", fields: [specimenCollectedById], references: [id], onDelete: SetNull)
  results               LabResult?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  invoiceItems          InvoiceItem[]

  @@index([encounterId])
  @@index([patientId])
  @@index([orderedById])
  @@index([fulfilledById])
  @@index([labTestCatalogId])
  @@index([specimenCollectedById])
}

model LabResult {
  id                     String    @id @default(uuid())
  labOrderId             String    @unique
  labOrder               LabOrder  @relation(fields: [labOrderId], references: [id], onDelete: Cascade)
  findings               String    @db.Text
  value                  Decimal?  @db.Decimal(10, 2)
  isAbnormal             Boolean?  @default(false)
  quantitativeData       Json?
  performingTechnicianId String?
  performingTechnician   User?     @relation("PerformingTechnicians", fields: [performingTechnicianId], references: [id], onDelete: SetNull)
  approvingPathologistId String?
  approvingPathologist   User?     @relation("ApprovingPathologists", fields: [approvingPathologistId], references: [id], onDelete: SetNull)
  recordedAt             DateTime  @default(now())
  validatedAt            DateTime?

  @@index([performingTechnicianId])
  @@index([approvingPathologistId])
}

// ================================
// PHARMACY LOOKUPS (BATCH 1)
// ================================

model Manufacturer {
  id          String     @id @default(cuid())
  name        String
  code        String     @unique
  description String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  medicines   Medicine[]

  @@index([name])
}

model MedicineCategory {
  id              String             @id @default(cuid())
  name            String
  description     String?
  parentId        String?
  parentCategory  MedicineCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  childCategories MedicineCategory[] @relation("CategoryHierarchy")
  isActive        Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?
  medicines       Medicine[]

  @@unique([name, parentId])
  @@index([name])
}

model DosageForm {
  id        String     @id @default(cuid())
  name      String     @unique
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?
  medicines Medicine[]

  @@index([name])
}

model AdministrationRoute {
  id             String             @id @default(cuid())
  name           String             @unique
  description    String?
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?
  approvedRoutes ApprovedRoute[]
  prescriptions  PrescriptionItem[]

  @@index([name])
}

model StorageLocation {
  id          String     @id @default(cuid())
  branchId    String
  name        String
  code        String
  description String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  medicines   Medicine[]

  branch  Branch          @relation(fields: [branchId], references: [id], onDelete: Restrict)
  batches MedicineBatch[]

  @@unique([branchId, code])
  @@index([branchId])
}

// ================================
// PHARMACY CLINICAL & SAFETY (BATCH 2)
// ================================

enum InteractionSeverity {
  CRITICAL
  WARNING
  INFORMATIONAL
}

enum AllergySeverity {
  MILD
  MODERATE
  SEVERE
}

model Medicine {
  id          String    @id @default(cuid())
  brandName   String
  genericName String
  sku         String?   @unique
  strength    String
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Relations to Batch 1 Lookups
  manufacturerId    String
  manufacturer      Manufacturer     @relation(fields: [manufacturerId], references: [id], onDelete: Restrict)
  categoryId        String
  category          MedicineCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  dosageFormId      String
  dosageForm        DosageForm       @relation(fields: [dosageFormId], references: [id], onDelete: Restrict)
  storageLocationId String?
  storageLocation   StorageLocation? @relation(fields: [storageLocationId], references: [id], onDelete: SetNull)

  // Relations to Batch 2 Models
  approvedRoutes ApprovedRoute[]
  allergies      PatientAllergy[]
  batches        MedicineBatch[]
  prescriptions  PrescriptionItem[]

  // Self-referencing drug interactions (A & B)
  interactionsA DrugInteraction[] @relation("MedicineA")
  interactionsB DrugInteraction[] @relation("MedicineB")

  @@index([brandName])
  @@index([genericName])
  @@index([categoryId])
  @@index([manufacturerId])
}

model ApprovedRoute {
  id         String    @id @default(cuid())
  medicineId String
  routeId    String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  medicine Medicine            @relation(fields: [medicineId], references: [id], onDelete: Cascade)
  route    AdministrationRoute @relation(fields: [routeId], references: [id], onDelete: Restrict)

  @@unique([medicineId, routeId])
  @@index([medicineId])
  @@index([routeId])
}

model DrugInteraction {
  id          String              @id @default(cuid())
  medicineAId String
  medicineBId String
  severity    InteractionSeverity
  description String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  deletedAt   DateTime?

  medicineA Medicine @relation("MedicineA", fields: [medicineAId], references: [id], onDelete: Cascade)
  medicineB Medicine @relation("MedicineB", fields: [medicineBId], references: [id], onDelete: Cascade)

  @@unique([medicineAId, medicineBId])
  @@index([medicineAId])
  @@index([medicineBId])
}

model PatientAllergy {
  id         String          @id @default(cuid())
  patientId  String
  medicineId String
  severity   AllergySeverity
  reaction   String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  deletedAt  DateTime?

  patient  Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  medicine Medicine @relation(fields: [medicineId], references: [id], onDelete: Restrict)

  @@unique([patientId, medicineId])
  @@index([patientId])
  @@index([medicineId])
}

// ================================
// PHARMACY INVENTORY (BATCH 3)
// ================================

enum InventoryTransactionType {
  STOCK_INTAKE
  STOCK_DISPENSE
  STOCK_TRANSFER
  STOCK_ADJUSTMENT
  STOCK_RETURN
}

model MedicineBatch {
  id                String    @id @default(cuid())
  medicineId        String
  batchNumber       String
  expiryDate        DateTime
  quantity          Int       @default(0)
  reorderLevel      Int       @default(10)
  purchasePrice     Decimal   @db.Decimal(10, 2)
  sellingPrice      Decimal   @db.Decimal(10, 2)
  storageLocationId String?
  branchId          String
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  medicine        Medicine               @relation(fields: [medicineId], references: [id], onDelete: Restrict)
  storageLocation StorageLocation?       @relation(fields: [storageLocationId], references: [id], onDelete: SetNull)
  branch          Branch                 @relation(fields: [branchId], references: [id], onDelete: Restrict)
  transactions    InventoryTransaction[]
  dispenseItems   DispenseItem[]

  @@unique([branchId, medicineId, batchNumber])
  @@index([medicineId])
  @@index([branchId])
  @@index([expiryDate])
}

model InventoryTransaction {
  id              String                   @id @default(cuid())
  medicineBatchId String
  type            InventoryTransactionType
  quantity        Int
  userId          String
  referenceId     String?
  notes           String?                  @db.Text
  createdAt       DateTime                 @default(now())

  medicineBatch MedicineBatch @relation(fields: [medicineBatchId], references: [id], onDelete: Restrict)
  user          User          @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([medicineBatchId])
  @@index([userId])
  @@index([createdAt])
}

// ================================
// PHARMACY PRESCRIPTIONS & DISPENSING (BATCH 4)
// ================================

enum PrescriptionStatus {
  PENDING
  PARTIALLY_DISPENSED
  DISPENSED
  CANCELLED
}

model Prescription {
  id          String             @id @default(cuid())
  patientId   String
  doctorId    String
  encounterId String?
  status      PrescriptionStatus @default(PENDING)
  notes       String?            @db.Text
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  deletedAt   DateTime?

  patient   Patient            @relation(fields: [patientId], references: [id], onDelete: Restrict)
  doctor    Doctor             @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  encounter Consultation?      @relation(fields: [encounterId], references: [id], onDelete: SetNull)
  items     PrescriptionItem[]
  dispenses DispenseRecord[]

  @@index([patientId])
  @@index([doctorId])
  @@index([status])
  @@index([createdAt])
}

model PrescriptionItem {
  id                String @id @default(cuid())
  prescriptionId    String
  medicineId        String
  quantity          Int
  dispensedQuantity Int    @default(0)
  dosageInstruction String @db.Text
  routeId           String

  prescription  Prescription        @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  medicine      Medicine            @relation(fields: [medicineId], references: [id], onDelete: Restrict)
  route         AdministrationRoute @relation(fields: [routeId], references: [id], onDelete: Restrict)
  dispenseItems DispenseItem[]

  @@index([prescriptionId])
  @@index([medicineId])
}

model DispenseRecord {
  id             String   @id @default(cuid())
  prescriptionId String
  pharmacistId   String
  witnessId      String?
  notes          String?  @db.Text
  createdAt      DateTime @default(now())

  prescription Prescription   @relation(fields: [prescriptionId], references: [id], onDelete: Restrict)
  pharmacist   User           @relation("PharmacistDispenses", fields: [pharmacistId], references: [id], onDelete: Restrict)
  witness      User?          @relation("WitnessDispenses", fields: [witnessId], references: [id], onDelete: SetNull)
  items        DispenseItem[]
  invoiceItems InvoiceItem[]

  @@index([prescriptionId])
  @@index([pharmacistId])
  @@index([createdAt])
}

model DispenseItem {
  id                 String @id @default(cuid())
  dispenseRecordId   String
  prescriptionItemId String
  medicineBatchId    String
  quantityDispensed  Int

  dispenseRecord   DispenseRecord   @relation(fields: [dispenseRecordId], references: [id], onDelete: Cascade)
  prescriptionItem PrescriptionItem @relation(fields: [prescriptionItemId], references: [id], onDelete: Restrict)
  medicineBatch    MedicineBatch    @relation(fields: [medicineBatchId], references: [id], onDelete: Restrict)

  @@index([dispenseRecordId])
  @@index([prescriptionItemId])
  @@index([medicineBatchId])
}

// ================================
// BILLING, INVOICES & TARIFFS (BILLING MODULE)
// ================================

enum InvoiceStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  VOIDED
}

enum PaymentMethod {
  CASH
  CARD
  MOBILE_MONEY
  INSURANCE
}

enum TariffCategory {
  CONSULTATION
  LABORATORY
  PHARMACY
  PROCEDURE
  OTHER
}

model Tariff {
  id        String         @id @default(cuid())
  branchId  String
  category  TariffCategory
  name      String
  code      String
  price     Decimal        @db.Decimal(10, 2)
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  deletedAt DateTime?

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Restrict)

  @@unique([branchId, code])
  @@index([branchId])
}

model Invoice {
  id          String        @id @default(cuid())
  patientId   String
  branchId    String
  status      InvoiceStatus @default(PENDING)
  totalAmount Decimal       @default(0) @db.Decimal(10, 2)
  paidAmount  Decimal       @default(0) @db.Decimal(10, 2)
  notes       String?       @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  patient  Patient       @relation(fields: [patientId], references: [id], onDelete: Restrict)
  branch   Branch        @relation(fields: [branchId], references: [id], onDelete: Restrict)
  items    InvoiceItem[]
  payments Payment[]

  @@index([patientId])
  @@index([branchId])
  @@index([status])
}

model InvoiceItem {
  id               String  @id @default(cuid())
  invoiceId        String
  name             String
  quantity         Int     @default(1)
  unitPrice        Decimal @db.Decimal(10, 2)
  totalPrice       Decimal @db.Decimal(10, 2)
  consultationId   String?
  labOrderId       String?
  dispenseRecordId String?

  invoice        Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  consultation   Consultation?   @relation(fields: [consultationId], references: [id], onDelete: SetNull)
  labOrder       LabOrder?       @relation(fields: [labOrderId], references: [id], onDelete: SetNull)
  dispenseRecord DispenseRecord? @relation(fields: [dispenseRecordId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([consultationId])
  @@index([labOrderId])
  @@index([dispenseRecordId])
}

model Payment {
  id              String        @id @default(cuid())
  invoiceId       String
  amount          Decimal       @db.Decimal(10, 2)
  method          PaymentMethod
  referenceNumber String?
  cashierId       String
  notes           String?       @db.Text
  createdAt       DateTime      @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  cashier User    @relation(fields: [cashierId], references: [id], onDelete: Restrict)

  @@index([invoiceId])
  @@index([cashierId])
}

// ================================
// INPATIENT DEPARTMENT (IPD WARD & BED MANAGEMENT MODULE)
// ================================

enum BedStatus {
  AVAILABLE
  OCCUPIED
  CLEANING
  MAINTENANCE
}

enum AdmissionStatus {
  ADMITTED
  DISCHARGED
  TRANSFERRED
}

model Ward {
  id              String    @id @default(cuid())
  branchId        String
  name            String
  code            String
  dailyTariffCode String
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Restrict)
  beds   Bed[]

  @@unique([branchId, code])
  @@index([branchId])
}

model Bed {
  id        String    @id @default(cuid())
  wardId    String
  bedNumber String
  status    BedStatus @default(AVAILABLE)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  ward       Ward        @relation(fields: [wardId], references: [id], onDelete: Cascade)
  admissions Admission[]

  @@unique([wardId, bedNumber])
  @@index([wardId])
  @@index([status])
}

model Admission {
  id                String          @id @default(cuid())
  patientId         String
  admittingDoctorId String
  bedId             String
  status            AdmissionStatus @default(ADMITTED)
  admissionDate     DateTime        @default(now())
  dischargeDate     DateTime?
  dischargeNotes    String?         @db.Text
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?

  patient         Patient     @relation(fields: [patientId], references: [id], onDelete: Restrict)
  admittingDoctor Doctor      @relation(fields: [admittingDoctorId], references: [id], onDelete: Restrict)
  bed             Bed         @relation(fields: [bedId], references: [id], onDelete: Restrict)
  vitalsLogs      VitalsLog[]

  @@index([patientId])
  @@index([admittingDoctorId])
  @@index([bedId])
  @@index([status])
}

model VitalsLog {
  id               String   @id @default(cuid())
  admissionId      String
  recordedById     String
  temperature      Decimal? @db.Decimal(4, 1)
  bloodPressure    String?
  heartRate        Int?
  respiratoryRate  Int?
  oxygenSaturation Int?
  notes            String?  @db.Text
  createdAt        DateTime @default(now())

  admission  Admission @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  recordedBy User      @relation(fields: [recordedById], references: [id], onDelete: Restrict)

  @@index([admissionId])
  @@index([recordedById])
}

// ================================
// SYSTEM AUDIT LOG (SA-001A)
// ================================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  actorRole  String?
  hospitalId String?
  branchId   String?
  action     String
  entity     String
  entityId   String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  statusCode Int?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([entity, entityId])
  @@index([createdAt])
  @@index([hospitalId])
  @@index([hospitalId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
}

// ================================
// PERMISSION MANAGEMENT (SA-001B)
// ================================

model Permission {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  description String?   @db.Text
  module      String
  resource    String
  action      String
  category    String
  isSystem    Boolean   @default(true)
  isActive    Boolean   @default(true)
  hospitalId  String?
  branchId    String?
  i18nKey     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  hospital Hospital? @relation(fields: [hospitalId], references: [id], onDelete: Restrict)
  branch   Branch?   @relation(fields: [branchId], references: [id], onDelete: Restrict)

  rolePermissions RolePermission[]
  userOverrides   UserPermissionOverride[]

  @@index([module])
  @@index([resource])
  @@index([action])
  @@index([category])
  @@index([isSystem])
  @@index([isActive])
  @@index([hospitalId])
  @@index([branchId])
  @@index([module, resource])
}

// ================================
// ROLE DEFINITION (SA-001C)
// ================================

model RoleDefinition {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String? @db.Text
  level       Int?    @default(0)

  isSystem   Boolean @default(false)
  isBuiltIn  Boolean @default(false)
  isActive   Boolean @default(true)
  isTemplate Boolean @default(false)

  hospitalId String?
  branchId   String?
  parentId   String?
  i18nKey    String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  hospital   Hospital?        @relation(fields: [hospitalId], references: [id], onDelete: Restrict)
  branch     Branch?          @relation(fields: [branchId], references: [id], onDelete: Restrict)
  parentRole RoleDefinition?  @relation("RoleHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  childRoles RoleDefinition[] @relation("RoleHierarchy")

  rolePermissions RolePermission[]
  apiKeys         ApiKey[]
  userRoles       UserRole[]

  @@unique([hospitalId, name])
  @@unique([branchId, name])
  @@index([isSystem])
  @@index([isBuiltIn])
  @@index([isActive])
  @@index([isTemplate])
  @@index([hospitalId])
  @@index([branchId])
  @@index([parentId])
  @@index([hospitalId, isActive])
  @@index([hospitalId, isBuiltIn])
  @@index([hospitalId, isTemplate])
}

// ================================
// ROLE PERMISSION JUNCTION (SA-001D)
// ================================

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  role       RoleDefinition @relation(fields: [roleId], references: [id], onDelete: Restrict)
  permission Permission     @relation(fields: [permissionId], references: [id], onDelete: Restrict)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

// ================================
// SYSTEM CONFIGURATION ENUMS (SA-001E)
// ================================

enum ConfigScope {
  GLOBAL
  HOSPITAL
  BRANCH
}

enum ConfigValueType {
  STRING
  NUMBER
  BOOLEAN
  JSON
  ENCRYPTED
}

enum ConfigCategory {
  SYSTEM
  SECURITY
  CLINICAL
  BILLING
  PHARMACY
  NOTIFICATION
  INTEGRATION
  AI
}

// ================================
// SYSTEM CONFIGURATION (SA-001E)
// ================================

model SystemConfig {
  id              String          @id @default(cuid())
  scope           ConfigScope
  key             String
  value           String          @db.Text
  valueType       ConfigValueType @default(STRING)
  category        ConfigCategory
  description     String?         @db.Text
  validationRules Json?

  isSystem    Boolean @default(false)
  isEncrypted Boolean @default(false)
  isActive    Boolean @default(true)

  hospitalId String?
  branchId   String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  hospital Hospital? @relation(fields: [hospitalId], references: [id], onDelete: Restrict)
  branch   Branch?   @relation(fields: [branchId], references: [id], onDelete: Restrict)

  @@unique([scope, hospitalId, branchId, key])
  @@index([key])
  @@index([category])
  @@index([isSystem])
  @@index([isActive])
  @@index([hospitalId])
  @@index([branchId])
  @@index([scope, key, isActive])
  @@index([hospitalId, isActive])
}

// ================================
// FEATURE FLAG ENUM (SA-001F)
// ================================

enum FeatureFlagScope {
  GLOBAL
  HOSPITAL
  BRANCH
}

// ================================
// FEATURE FLAG (SA-001F)
// ================================

model FeatureFlag {
  id                String           @id @default(cuid())
  key               String
  name              String
  description       String?          @db.Text
  enabled           Boolean          @default(false)
  scope             FeatureFlagScope
  rolloutPercentage Int?             @default(100)
  metadata          Json?

  isSystem Boolean @default(false)

  hospitalId String?
  branchId   String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  hospital Hospital? @relation(fields: [hospitalId], references: [id], onDelete: Restrict)
  branch   Branch?   @relation(fields: [branchId], references: [id], onDelete: Restrict)

  @@unique([scope, hospitalId, branchId, key])
  @@index([key])
  @@index([enabled])
  @@index([isSystem])
  @@index([hospitalId])
  @@index([branchId])
  @@index([scope, key, enabled])
}

// ================================
// API KEY ENUMS (SA-001G)
// ================================

enum ApiKeyScope {
  GLOBAL
  HOSPITAL
  BRANCH
}

enum ApiKeyType {
  SYSTEM_INTEGRATION
  PARTNER_API
  IOT_DEVICE
  DEVELOPER
}

enum ApiKeyStatus {
  ACTIVE
  SUSPENDED
  REVOKED
  EXPIRED
}

enum ApiKeyEnvironment {
  DEVELOPMENT
  TESTING
  STAGING
  PRODUCTION
}

// ================================
// API KEY MANAGEMENT (SA-001G)
// ================================

model ApiKey {
  id          String            @id @default(cuid())
  name        String
  keyPrefix   String            @unique
  hashedKey   String            @unique
  description String?           @db.Text
  type        ApiKeyType        @default(SYSTEM_INTEGRATION)
  status      ApiKeyStatus      @default(ACTIVE)
  scope       ApiKeyScope       @default(GLOBAL)
  environment ApiKeyEnvironment @default(PRODUCTION)

  expiresAt      DateTime?
  lastUsedAt     DateTime?
  lastUsedIp     String?
  failedAttempts Int       @default(0)
  lastFailedAt   DateTime?

  rotatedFromId String?
  roleId        String?
  hospitalId    String?
  branchId      String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  rotatedFrom ApiKey?         @relation("ApiKeyRotation", fields: [rotatedFromId], references: [id], onDelete: SetNull)
  rotatedKeys ApiKey[]        @relation("ApiKeyRotation")
  role        RoleDefinition? @relation(fields: [roleId], references: [id], onDelete: Restrict)
  hospital    Hospital?       @relation(fields: [hospitalId], references: [id], onDelete: Restrict)
  branch      Branch?         @relation(fields: [branchId], references: [id], onDelete: Restrict)

  @@index([type])
  @@index([status])
  @@index([environment])
  @@index([roleId])
  @@index([hospitalId])
  @@index([branchId])
  @@index([rotatedFromId])
  @@index([keyPrefix, status, deletedAt])
}

// ================================
// USER ROLE JUNCTION (SA-001H)
// ================================

model UserRole {
  id         String  @id @default(cuid())
  userId     String
  roleId     String
  hospitalId String?
  branchId   String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user     User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  role     RoleDefinition @relation(fields: [roleId], references: [id], onDelete: Restrict)
  hospital Hospital?      @relation(fields: [hospitalId], references: [id], onDelete: Restrict)
  branch   Branch?        @relation(fields: [branchId], references: [id], onDelete: Restrict)

  @@unique([userId, roleId, hospitalId, branchId])
  @@index([userId])
  @@index([roleId])
  @@index([hospitalId])
  @@index([branchId])
}

// ================================
// USER PERMISSION OVERRIDE (SA-001I)
// ================================

model UserPermissionOverride {
  id           String    @id @default(cuid())
  userId       String
  permissionId String
  isGranted    Boolean   @default(true)
  reason       String?   @db.Text
  expiresAt    DateTime?

  hospitalId String?
  branchId   String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user       User       @relation(fields: [userId], references: [id], onDelete: Restrict)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Restrict)
  hospital   Hospital?  @relation(fields: [hospitalId], references: [id], onDelete: Restrict)
  branch     Branch?    @relation(fields: [branchId], references: [id], onDelete: Restrict)

  @@unique([userId, permissionId, hospitalId, branchId])
  @@index([userId])
  @@index([permissionId])
  @@index([isGranted])
}
