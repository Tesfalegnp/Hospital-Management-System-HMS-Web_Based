# ======================================================
# APPLICATION
# ======================================================
NODE_ENV=development
PORT=5000
API_PREFIX=/api
API_VERSION=v1
CLIENT_URL=http://localhost:5173

# ======================================================
# DATABASE (Prisma)
# ======================================================
# DATABASE_URL -> Supabase Pooler (Transaction Mode, port 6543)
# Used for application database queries with connection pooling.
DATABASE_URL="postgresql://[user].[project-ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# DIRECT_URL -> Supabase Pooler (Session Mode, port 5432)
# Used for Prisma migrations. Required for environments without native IPv6 routing support.
DIRECT_URL="postgresql://[user].[project-ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# ======================================================
# JWT Authentication
# ======================================================
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_characters
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret_at_least_32_characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ======================================================
# Cookies
# ======================================================
COOKIE_NAME=hms_refresh_token
COOKIE_SECURE=false
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=lax

# ======================================================
# Logging & File Uploads
# ======================================================
LOG_LEVEL=info
MAX_FILE_SIZE=5242880
UPLOAD_PATH=uploads
